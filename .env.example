# Supabase (local: run `pnpm db:start` then `pnpm supabase status` for keys)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: link cloud project
# SUPABASE_PROJECT_REF=your-project-ref

# Seed admin (scripts/seed.ts)
SEED_ADMIN_EMAIL=admin@ticqex.local
SEED_ADMIN_PASSWORD=ticqex-admin-change-me

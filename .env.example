# Supabase (local: `pnpm db:start` then `pnpm db:env` to sync keys into .env.local)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Seed admin (scripts/seed.ts)
SEED_ADMIN_EMAIL=admin@ticqex.local
SEED_ADMIN_PASSWORD=ticqex-admin-change-me

# Email (Phase 3 — optional for local dev)
RESEND_API_KEY=re_...
RESEND_INBOUND_WEBHOOK_SECRET=whsec_...
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_FROM_NAME=Support

# Trigger.dev — run `pnpm trigger:login`, `pnpm trigger:create`, `pnpm trigger:env`
TRIGGER_SECRET_KEY=tr_dev_...
TRIGGER_PROJECT_REF=proj_your_project_ref

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

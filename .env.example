# Supabase (local: `pnpm db:start` then `pnpm db:env`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Seed admin (scripts/seed.ts)
SEED_ADMIN_EMAIL=admin@ticqex.local
SEED_ADMIN_PASSWORD=ticqex-admin-change-me

# Email — Resend (required for inbound/outbound)
RESEND_API_KEY=re_...
RESEND_INBOUND_WEBHOOK_SECRET=whsec_...
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_FROM_NAME=Support

# Trigger.dev — `pnpm trigger:login`, `pnpm trigger:create`, `pnpm env:sync`
TRIGGER_SECRET_KEY=tr_dev_...
TRIGGER_PROJECT_REF=proj_your_project_ref
# Non-interactive CLI auth (Cursor Cloud harness only — not written to .env.local)
# TRIGGER_ACCESS_TOKEN=tr_pat_...

# App URL (public tunnel hostname when using Cloudflare)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare named tunnel (Cursor Cloud harness only — not written to .env.local)
# CLOUDFLARE_TUNNEL_TOKEN=...
